<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NPS 问卷投放 — 需求评审</title>
  <!--
    SPEC REVIEW TEMPLATE v4.0
    章节顺序:
      1) 产品概述
      2) 业务流程        含端到端流转胶囊条 + Tab 切换（顶部）
      3) 功能架构
      4) 模块详情        左右联动
      5) 原型预览        筛选 + lightbox
      6) 角色与权限      左侧 Tab
      7) 全局规范        左侧 Tab
      8) 方案设计        左侧 Tab：技术架构/数据模型/部署/决策/错误码
      9) Spec Coding 指引
     10) AI 评审摘要
     11) 开放问题
  -->
  <style>
    :root {
      --bg:#fff; --bg-soft:#f8fafc; --bg-muted:#f1f5f9;
      --fg:#0f172a; --fg-muted:#64748b; --fg-soft:#94a3b8;
      --border:#e2e8f0; --border-soft:#f1f5f9;
      --primary:#1d4ed8; --primary-soft:#eff6ff;
      --radius:0.5rem; --radius-lg:0.75rem;
      --shadow-xs:0 1px 2px 0 rgba(15,23,42,.04);
      --shadow-sm:0 1px 3px rgba(15,23,42,.06),0 1px 2px rgba(15,23,42,.04);
      --shadow-md:0 6px 16px rgba(15,23,42,.08),0 2px 4px rgba(15,23,42,.04);
    }
    .clr-blue   { --c-bg:#eff6ff; --c-border:#dbeafe; --c-fg:#1e40af; --c-strong:#1d4ed8; }
    .clr-green  { --c-bg:#ecfdf5; --c-border:#d1fae5; --c-fg:#047857; --c-strong:#059669; }
    .clr-purple { --c-bg:#faf5ff; --c-border:#f3e8ff; --c-fg:#7e22ce; --c-strong:#9333ea; }
    .clr-orange { --c-bg:#fff7ed; --c-border:#ffedd5; --c-fg:#c2410c; --c-strong:#ea580c; }
    .clr-red    { --c-bg:#fef2f2; --c-border:#fee2e2; --c-fg:#b91c1c; --c-strong:#dc2626; }
    .clr-amber  { --c-bg:#fffbeb; --c-border:#fef3c7; --c-fg:#b45309; --c-strong:#d97706; }
    .clr-indigo { --c-bg:#eef2ff; --c-border:#e0e7ff; --c-fg:#4338ca; --c-strong:#4f46e5; }
    .clr-teal   { --c-bg:#f0fdfa; --c-border:#ccfbf1; --c-fg:#0f766e; --c-strong:#0d9488; }
    .clr-rose   { --c-bg:#fff1f2; --c-border:#ffe4e6; --c-fg:#be123c; --c-strong:#e11d48; }
    .clr-slate  { --c-bg:#f8fafc; --c-border:#e2e8f0; --c-fg:#475569; --c-strong:#334155; }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: ui-sans-serif, system-ui, -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
      font-size: 15px; line-height: 1.65;
      color: var(--fg); background: white;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--primary); text-decoration: none; }
    a:hover { text-decoration: underline; }
    h1,h2,h3,h4 { margin: 0; line-height: 1.3; letter-spacing: -0.015em; font-weight: 600; }
    p { margin: 0; }
    code {
      padding: 0.125rem 0.4rem; background: var(--bg-muted);
      border-radius: 0.25rem; font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      font-size: 0.85em; color: var(--fg);
    }
    img { max-width: 100%; display: block; }

    /* ===== Nav ===== */
    .nav {
      position: sticky; top: 0; z-index: 50;
      background: rgba(255,255,255,.85);
      backdrop-filter: saturate(180%) blur(12px);
      -webkit-backdrop-filter: saturate(180%) blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner { max-width: 1280px; margin: 0 auto; padding: 0.875rem 1.5rem; display: flex; align-items: center; gap: 1.5rem; }
    .nav-brand { display: flex; align-items: center; gap: 0.625rem; font-weight: 600; font-size: 0.95rem; }
    .nav-brand-icon { width: 1.75rem; height: 1.75rem; border-radius: 0.5rem; background: linear-gradient(135deg,#1d4ed8 0%,#4f46e5 100%); color: white; display: grid; place-items: center; font-size: 0.85rem; font-weight: 700; }
    .nav-links { display: flex; gap: 0.125rem; flex-wrap: wrap; margin-left: auto; }
    .nav-links a { padding: 0.4rem 0.625rem; border-radius: 0.375rem; color: var(--fg-muted); font-size: 0.825rem; font-weight: 500; transition: all 0.12s; }
    .nav-links a:hover { background: var(--bg-muted); color: var(--fg); text-decoration: none; }
    .nav-links a.active { background: var(--fg); color: white; }

    .container { max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; }
    section { padding: 4rem 0 1rem; scroll-margin-top: 4.5rem; position: relative; }
    /* Alternating section background — odd: white, even: soft */
    section.section-alt { background: var(--bg-soft); }
    section.section-alt::before, section.section-alt::after {
      content: ''; position: absolute; left: calc(50% - 50vw); right: calc(50% - 50vw);
      width: 100vw; background: var(--bg-soft); top: 0; bottom: 0; z-index: -1;
    }

    /* ===== Hero ===== */
    .hero { position: relative; padding: 4.5rem 0 3.5rem; background: linear-gradient(180deg,#fff 0%,var(--bg-soft) 100%); border-bottom: 1px solid var(--border); overflow: hidden; }
    .hero::before { content:''; position: absolute; inset: 0; pointer-events: none; background-image: radial-gradient(circle at 15% 20%, rgba(59,130,246,.08), transparent 40%), radial-gradient(circle at 85% 80%, rgba(168,85,247,.08), transparent 40%); }
    .hero .container { position: relative; }
    .hero-meta { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.75rem; border-radius: 9999px; background: white; border: 1px solid var(--border); font-size: 0.8rem; color: var(--fg-muted); margin-bottom: 1.25rem; box-shadow: var(--shadow-xs); }
    .pulse { width: 0.5rem; height: 0.5rem; border-radius: 9999px; background: #10b981; box-shadow: 0 0 0 4px rgba(16,185,129,.18); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{box-shadow:0 0 0 4px rgba(16,185,129,.18);} 50%{box-shadow:0 0 0 6px rgba(16,185,129,.25);} }
    .hero h1 { font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 700; letter-spacing: -0.025em; margin-bottom: 1rem; }
    .hero h1 .accent { background: linear-gradient(135deg,#1d4ed8 0%,#7e22ce 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
    .hero p.lead { font-size: 1.075rem; color: var(--fg-muted); max-width: 44rem; margin-bottom: 1.75rem; }
    .hero-cta { display: flex; gap: 0.625rem; flex-wrap: wrap; }
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1.125rem; background: var(--fg); color: white; border-radius: var(--radius); font-weight: 500; font-size: 0.875rem; border: none; cursor: pointer; transition: opacity 0.15s, transform 0.05s; box-shadow: var(--shadow-sm); }
    .btn:hover { opacity: 0.92; text-decoration: none; }
    .btn:active { transform: translateY(1px); }
    .btn-ghost { background: white; color: var(--fg); border: 1px solid var(--border); }

    .hero-stats { margin-top: 2.5rem; display: grid; grid-template-columns: repeat(4,1fr); gap: 0.875rem; }
    .hero-stat { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.125rem 1.25rem; box-shadow: var(--shadow-xs); position: relative; overflow: hidden; }
    .hero-stat::after { content:''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--c-strong, var(--primary)); }
    .hero-stat-value { font-size: 1.75rem; font-weight: 700; line-height: 1; color: var(--fg); letter-spacing: -0.02em; }
    .hero-stat-label { font-size: 0.78rem; color: var(--fg-muted); margin-top: 0.5rem; font-weight: 500; }
    .hero-stat-sub { font-size: 0.7rem; color: var(--fg-soft); margin-top: 0.25rem; }
    @media (max-width: 768px) { .hero-stats { grid-template-columns: repeat(2,1fr); } .nav-links { display: none; } }

    /* ===== Section ===== */
    .section-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
    .section-eyebrow { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.74rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.5rem; }
    .section-eyebrow-dot { width: 0.375rem; height: 0.375rem; border-radius: 9999px; }
    .section-title { font-size: 1.625rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.5rem; }
    .section-subtitle { color: var(--fg-muted); font-size: 0.95rem; max-width: 56rem; }
    .section-side-meta { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.75rem; border-radius: 9999px; background: white; border: 1px solid var(--border); font-size: 0.8rem; color: var(--fg-muted); box-shadow: var(--shadow-xs); }

    /* ===== Cards ===== */
    .card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; box-shadow: var(--shadow-xs); }
    .card-hover { transition: all 0.18s; }
    .card-hover:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--c-border, var(--border)); }
    .card-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.875rem; }
    .card-icon { width: 2.25rem; height: 2.25rem; border-radius: var(--radius); display: grid; place-items: center; background: var(--c-bg, var(--primary-soft)); color: var(--c-strong, var(--primary)); flex-shrink: 0; }
    .card-title { font-size: 1rem; font-weight: 600; }
    .card-desc { color: var(--fg-muted); font-size: 0.9rem; line-height: 1.6; }

    .grid { display: grid; gap: 1rem; }
    .grid-2 { grid-template-columns: repeat(2,1fr); }
    .grid-3 { grid-template-columns: repeat(3,1fr); }
    .grid-4 { grid-template-columns: repeat(4,1fr); }
    @media (max-width: 1024px) { .grid-3, .grid-4 { grid-template-columns: repeat(2,1fr); } }
    @media (max-width: 640px) { .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; } .hero h1 { font-size: 2rem; } }

    .tag { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.125rem 0.5rem; border-radius: 0.375rem; border: 1px solid var(--c-border); background: var(--c-bg); color: var(--c-fg); font-size: 0.72rem; font-weight: 500; }
    .badge { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.72rem; font-weight: 500; background: var(--c-bg); color: var(--c-fg); border: 1px solid var(--c-border); }
    .badge-success { --c-bg:#d1fae5; --c-fg:#065f46; --c-border:#a7f3d0; }
    .badge-warning { --c-bg:#fef3c7; --c-fg:#92400e; --c-border:#fde68a; }
    .badge-danger { --c-bg:#fee2e2; --c-fg:#991b1b; --c-border:#fecaca; }
    .badge-info { --c-bg:#dbeafe; --c-fg:#1e40af; --c-border:#bfdbfe; }
    .badge-neutral { --c-bg: var(--bg-muted); --c-fg: var(--fg-muted); --c-border: var(--border); }

    .table-wrap { border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; background: white; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    thead { background: var(--bg-soft); }
    th { padding: 0.75rem 1rem; text-align: left; font-weight: 600; font-size: 0.74rem; color: var(--fg-muted); letter-spacing: 0.05em; text-transform: uppercase; border-bottom: 1px solid var(--border); }
    td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--border-soft); vertical-align: top; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: var(--bg-soft); }

    .checklist { list-style: none; padding: 0; margin: 0; }
    .checklist li { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.625rem 0; font-size: 0.9rem; border-bottom: 1px solid var(--border-soft); }
    .checklist li:last-child { border-bottom: none; }
    .check-icon { flex-shrink: 0; width: 1.25rem; height: 1.25rem; border-radius: 9999px; display: grid; place-items: center; margin-top: 0.0625rem; font-size: 0.7rem; font-weight: 700; }
    .check-icon.success { background: #d1fae5; color: #047857; }
    .check-icon.warning { background: #fef3c7; color: #b45309; }
    .check-icon.info { background: #dbeafe; color: #1e40af; }

    /* ===== Pill tabs (used for §2 flows top — unified with .arch-sub / .proto-filter) ===== */
    .tabs-top { display: flex; gap: 0.375rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .tabs-top .tab-btn { padding: 0.5rem 1rem; border-radius: var(--radius); background: white; border: 1px solid var(--border); color: var(--fg-muted); font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: all 0.12s; display: inline-flex; align-items: center; gap: 0.375rem; }
    .tabs-top .tab-btn:hover { color: var(--fg); }
    .tabs-top .tab-btn.active { background: var(--fg); color: white; border-color: var(--fg); }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }

    /* ===== Side-tabs (used for §6/7/8/9) — same DOM as modsplit ===== */
    .splitview { display: grid; grid-template-columns: 16rem 1fr; gap: 1.25rem; align-items: stretch; }
    @media (max-width: 880px) { .splitview { grid-template-columns: 1fr; } .splitview-list { max-height: 18rem; overflow-y: auto; position: static !important; } }
    .splitview-list { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 0.5rem; box-shadow: var(--shadow-xs); align-self: start; position: sticky; top: 5rem; }
    .splitview-item { display: flex; align-items: center; gap: 0.625rem; padding: 0.625rem 0.75rem; border-radius: var(--radius); cursor: pointer; transition: all 0.12s; user-select: none; border: 1px solid transparent; }
    .splitview-item:hover { background: var(--bg-soft); }
    .splitview-item.active { background: var(--c-bg, var(--primary-soft)); border-color: var(--c-border, var(--primary-soft)); }
    .splitview-item .sv-id { width: 2.25rem; padding: 0.125rem 0.375rem; background: var(--bg-muted); color: var(--fg-muted); border-radius: 0.25rem; font-size: 0.72rem; font-weight: 700; text-align: center; flex-shrink: 0; }
    .splitview-item.active .sv-id { background: var(--c-strong); color: white; }
    .splitview-item .sv-name { font-size: 0.875rem; font-weight: 500; color: var(--fg); flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .splitview-item .sv-icon { font-size: 1rem; line-height: 1; flex-shrink: 0; }
    .splitview-detail { min-height: 22rem; }
    .sv-pane { display: none; }
    .sv-pane.active { display: block; }

    /* ===== Module head + blocks (reused for module + design panes) ===== */
    .modhead { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem 1.5rem; margin-bottom: 1rem; box-shadow: var(--shadow-xs); }
    .modhead-meta { display: flex; gap: 0.375rem; flex-wrap: wrap; align-items: center; margin-bottom: 0.5rem; }
    .modhead-title { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
    .modhead-desc { color: var(--fg-muted); font-size: 0.925rem; }
    .modgrid { display: grid; gap: 1rem; }
    @media (min-width: 720px) { .modgrid.cols-2 { grid-template-columns: 1fr 1fr; } }
    .modblock { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; }
    .modblock h4 { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--fg-muted); margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.375rem; }
    .modblock ul { list-style: none; padding: 0; margin: 0; font-size: 0.875rem; color: var(--fg); }
    .modblock ul li { padding: 0.3125rem 0; line-height: 1.55; }
    .modblock ul li::before { content: '·'; color: var(--c-strong, var(--primary)); margin-right: 0.5rem; font-weight: 700; }
    .modblock .br-list li { display: flex; gap: 0.625rem; align-items: flex-start; padding: 0.5rem 0; border-bottom: 1px dashed var(--border-soft); }
    .modblock .br-list li:last-child { border-bottom: none; }
    .modblock .br-list li::before { display: none; }
    .modblock .br-code { background: var(--bg-muted); color: var(--fg-muted); padding: 0.0625rem 0.4rem; border-radius: 0.25rem; font-family: ui-monospace, monospace; font-size: 0.75rem; font-weight: 600; flex-shrink: 0; margin-top: 0.0625rem; }
    .modlink { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.375rem 0.75rem; background: var(--c-bg, var(--primary-soft)); border: 1px solid var(--c-border, var(--primary-soft)); color: var(--c-strong, var(--primary)); border-radius: var(--radius); font-size: 0.825rem; font-weight: 500; cursor: pointer; }
    .modlink:hover { text-decoration: none; opacity: 0.9; }

    /* ===== Function tree (Architecture) ===== */
    .fntree { background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; }
    .fntree-row { display: grid; gap: 1rem; }
    @media (min-width: 800px) { .fntree-row.cols-2 { grid-template-columns: 1fr 1fr; } }
    .fntree-layer { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1rem 1.25rem; }
    .fntree-layer-head { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.75rem; padding-bottom: 0.625rem; border-bottom: 1px dashed var(--border); }
    .fntree-layer-icon { width: 1.75rem; height: 1.75rem; border-radius: var(--radius); display: grid; place-items: center; background: var(--c-bg); color: var(--c-strong); font-size: 0.875rem; }
    .fntree-layer-title { font-size: 0.95rem; font-weight: 600; color: var(--fg); }
    .fntree-layer-sub { font-size: 0.78rem; color: var(--fg-muted); margin-top: 0.0625rem; }
    .fntree-modules { display: grid; gap: 0.5rem; }
    .fntree-mod { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; border-radius: var(--radius); background: var(--c-bg); color: var(--c-fg); border: 1px solid var(--c-border); font-size: 0.85rem; font-weight: 500; }
    .fntree-mod-id { width: 2.5rem; padding: 0.125rem 0.375rem; background: white; color: var(--c-strong); border-radius: 0.25rem; font-size: 0.7rem; font-weight: 700; text-align: center; flex-shrink: 0; border: 1px solid var(--c-border); }

    /* ===== Mermaid + image cards ===== */
    .mermaid-wrap { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.5rem; overflow-x: auto; box-shadow: var(--shadow-xs); }
    .mermaid-wrap pre { margin: 0; text-align: center; font-family: ui-monospace, monospace; font-size: 0.85rem; }
    .flowimg { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1rem; box-shadow: var(--shadow-xs); text-align: center; }
    .flowimg img { max-width: 100%; border-radius: var(--radius); cursor: zoom-in; margin: 0 auto; }
    .flowimg-caption { color: var(--fg-muted); font-size: 0.85rem; margin-top: 0.75rem; }

    /* ===== Process strip (核心流程胶囊条 — 紧凑版，可滚动) ===== */
    .process-strip {
      background: linear-gradient(180deg, white 0%, var(--bg-soft) 100%);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.25rem 1.5rem 1.5rem;
      margin-bottom: 1.5rem;
      box-shadow: var(--shadow-xs);
      overflow-x: auto;
    }
    .process-strip-title {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.74rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--fg-muted); margin-bottom: 1.125rem;
    }
    .process-strip-title::before {
      content: ''; width: 0.375rem; height: 0.375rem; border-radius: 9999px;
      background: var(--primary);
    }
    .process-strip-flow {
      display: flex; align-items: flex-start; gap: 0;
      min-width: max-content; padding-top: 0.25rem;
    }
    .process-step {
      flex: 0 0 7.5rem;
      display: flex; flex-direction: column; align-items: center; text-align: center;
      background: transparent; border: none; padding: 0 0.5rem;
      position: relative;
    }
    /* Connecting line between number badges */
    .process-step::after {
      content: '';
      position: absolute;
      top: 0.875rem;
      left: 50%;
      width: 100%;
      height: 2px;
      background: var(--border);
      z-index: 0;
    }
    .process-step:last-child::after { display: none; }
    .process-step-num {
      position: relative; z-index: 1;
      width: 1.75rem; height: 1.75rem;
      background: white; color: var(--fg);
      border: 2px solid var(--border);
      border-radius: 9999px;
      display: grid; place-items: center;
      font-size: 0.75rem; font-weight: 700;
      margin-bottom: 0.625rem;
      transition: all 0.15s;
    }
    .process-step:hover .process-step-num {
      background: var(--fg); color: white; border-color: var(--fg);
      transform: scale(1.08);
    }
    .process-step-name {
      font-size: 0.825rem; font-weight: 600; color: var(--fg);
      line-height: 1.3; margin-bottom: 0.125rem;
    }
    .process-step-actor {
      font-size: 0.7rem; color: var(--fg-muted);
      line-height: 1.3;
    }
    /* Legacy text arrows are hidden — line replaces them */
    .process-arrow { display: none; }

    /* ===== Decision card ===== */
    .decision-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.375rem; transition: all 0.18s; }
    .decision-card:hover { border-color: var(--c-border, var(--primary-soft)); box-shadow: var(--shadow-md); }
    .decision-head { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.625rem; }
    .decision-num { width: 1.75rem; height: 1.75rem; border-radius: 0.5rem; background: var(--c-bg, var(--primary-soft)); color: var(--c-strong, var(--primary)); display: grid; place-items: center; font-size: 0.75rem; font-weight: 700; flex-shrink: 0; }
    .decision-title { font-size: 0.95rem; font-weight: 600; }
    .decision-choice { display: inline-flex; padding: 0.25rem 0.625rem; background: var(--c-bg, var(--bg-muted)); color: var(--c-strong, var(--fg)); border: 1px solid var(--c-border, var(--border)); border-radius: 0.375rem; font-size: 0.825rem; font-weight: 600; margin: 0.5rem 0; }
    .decision-reason { font-size: 0.875rem; color: var(--fg-muted); line-height: 1.55; }

    /* ===== OQ ===== */
    .oq-card { background: white; border: 1px solid var(--border); border-left: 3px solid #f59e0b; border-radius: var(--radius-lg); padding: 1.125rem 1.375rem; margin-bottom: 0.75rem; box-shadow: var(--shadow-xs); }
    .oq-id { display: inline-block; font-size: 0.7rem; font-weight: 700; color: #b45309; letter-spacing: 0.05em; background: #fef3c7; padding: 0.125rem 0.5rem; border-radius: 0.25rem; margin-bottom: 0.5rem; }
    .oq-q { font-weight: 600; color: var(--fg); margin-bottom: 0.5rem; }
    .oq-default { font-size: 0.875rem; color: var(--fg-muted); }
    .oq-default strong { color: #b45309; }

    /* ===== Prototype ===== */
    .proto-filter { display: flex; gap: 0.375rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .proto-filter-btn { padding: 0.375rem 0.75rem; border-radius: 9999px; background: white; border: 1px solid var(--border); color: var(--fg-muted); font-size: 0.825rem; font-weight: 500; cursor: pointer; transition: all 0.12s; }
    .proto-filter-btn:hover { color: var(--fg); }
    .proto-filter-btn.active { background: var(--fg); color: white; border-color: var(--fg); }
    .proto-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); }
    .proto-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; cursor: zoom-in; transition: all 0.18s; }
    .proto-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .proto-card-img { aspect-ratio: 4/3; background: var(--bg-muted); overflow: hidden; display: grid; place-items: center; }
    .proto-card-img img { width: 100%; height: 100%; object-fit: contain; }
    .proto-card-meta { padding: 0.625rem 0.875rem; }
    .proto-card-name { font-size: 0.875rem; font-weight: 600; margin-bottom: 0.125rem; }
    .proto-card-mod { font-size: 0.74rem; color: var(--fg-muted); }

    /* ===== Lightbox ===== */
    .lightbox { position: fixed; inset: 0; z-index: 100; background: rgba(15,23,42,.92); display: none; align-items: center; justify-content: center; padding: 2rem; }
    .lightbox.active { display: flex; }
    .lightbox img { max-width: 100%; max-height: 90vh; border-radius: var(--radius); cursor: zoom-out; }
    .lightbox-close { position: absolute; top: 1rem; right: 1.5rem; width: 2.5rem; height: 2.5rem; border-radius: 9999px; background: rgba(255,255,255,.15); color: white; display: grid; place-items: center; border: none; cursor: pointer; font-size: 1.5rem; font-weight: 300; }
    .lightbox-cap { position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%); color: white; font-size: 0.9rem; opacity: 0.8; }

    /* ===== Feature tags (key features cloud) ===== */
    .feature-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
    .feature-tag { padding: 0.375rem 0.75rem; background: var(--c-bg, var(--primary-soft)); color: var(--c-strong, var(--primary)); border: 1px solid var(--c-border, var(--primary-soft)); border-radius: 9999px; font-size: 0.825rem; font-weight: 500; display: inline-flex; align-items: center; gap: 0.25rem; }

    /* ===== Journey step cards (业务流程详细 10 步) ===== */
    .journey { display: grid; gap: 0.75rem; }
    .journey-step { display: grid; grid-template-columns: 2.5rem 1fr; gap: 1rem; align-items: start; padding: 1rem 1.25rem; background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); transition: all 0.18s; }
    .journey-step:hover { border-color: var(--c-border, var(--primary-soft)); box-shadow: var(--shadow-md); }
    .journey-num { width: 2.5rem; height: 2.5rem; border-radius: 9999px; background: var(--c-bg, var(--primary-soft)); color: var(--c-strong, var(--primary)); display: grid; place-items: center; font-weight: 700; font-size: 1rem; flex-shrink: 0; }
    .journey-content { flex: 1; }
    .journey-head { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.375rem; }
    .journey-title { font-size: 1rem; font-weight: 600; color: var(--fg); }
    .journey-meta { display: flex; gap: 0.375rem; flex-wrap: wrap; }
    .journey-actor { padding: 0.125rem 0.5rem; background: var(--bg-muted); color: var(--fg-muted); border-radius: 0.25rem; font-size: 0.72rem; font-weight: 500; }
    .journey-mod { padding: 0.125rem 0.5rem; background: var(--c-bg); color: var(--c-strong); border: 1px solid var(--c-border); border-radius: 0.25rem; font-size: 0.72rem; font-weight: 600; }
    .journey-desc { font-size: 0.875rem; color: var(--fg-muted); line-height: 1.55; }

    /* ===== Mini module cards (评审摘要速查) ===== */
    .mini-mod-grid { display: grid; gap: 0.625rem; grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr)); }
    .mini-mod { padding: 0.625rem 0.875rem; background: white; border: 1px solid var(--border); border-radius: var(--radius); border-left: 3px solid var(--c-strong, var(--primary)); transition: all 0.15s; }
    .mini-mod:hover { transform: translateY(-1px); box-shadow: var(--shadow-sm); }
    .mini-mod-id { font-size: 0.7rem; color: var(--c-strong); font-weight: 700; letter-spacing: 0.05em; }
    .mini-mod-name { font-size: 0.875rem; font-weight: 600; color: var(--fg); margin-top: 0.125rem; }
    .mini-mod-meta { display: flex; gap: 0.25rem; margin-top: 0.375rem; }
    .mini-mod-meta .badge { font-size: 0.66rem; padding: 0.0625rem 0.375rem; }

    /* ===== Proto stats (原型分类统计) ===== */
    .proto-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-top: 1.5rem; }
    .proto-stat { background: white; border: 1px solid var(--border); border-radius: var(--radius); padding: 0.875rem 1rem; text-align: center; border-top: 3px solid var(--c-strong); }
    .proto-stat-value { font-size: 1.5rem; font-weight: 700; color: var(--fg); line-height: 1; }
    .proto-stat-label { font-size: 0.78rem; color: var(--fg-muted); margin-top: 0.375rem; }
    @media (max-width: 768px) { .proto-stats { grid-template-columns: repeat(2, 1fr); } }

    .arch-sub { display: flex; gap: 0.375rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .arch-sub-btn { padding: 0.5rem 1rem; border-radius: var(--radius); background: white; border: 1px solid var(--border); color: var(--fg-muted); font-size: 0.85rem; font-weight: 500; cursor: pointer; transition: all 0.12s; display: inline-flex; align-items: center; gap: 0.375rem; }
    .arch-sub-btn:hover { color: var(--fg); }
    .arch-sub-btn.active { background: var(--fg); color: white; border-color: var(--fg); }
    .arch-pane { display: none; }
    .arch-pane.active { display: block; }
    .arch-layer-card { display: flex; align-items: center; gap: 1rem; padding: 0.875rem 1.25rem; background: white; border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 0.5rem; }
    .arch-layer-tag { width: 7rem; padding: 0.25rem 0.5rem; background: var(--c-bg); color: var(--c-strong); border: 1px solid var(--c-border); border-radius: 0.25rem; font-size: 0.78rem; font-weight: 600; text-align: center; flex-shrink: 0; }
    .arch-layer-content { flex: 1; font-size: 0.875rem; color: var(--fg); }

    /* ===== Hero TL;DR cards ===== */
    .hero-tldr { margin-top: 1.5rem; display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.875rem; }
    .hero-tldr-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1rem 1.125rem; box-shadow: var(--shadow-xs); }
    .hero-tldr-head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.625rem; }
    .hero-tldr-icon { width: 1.5rem; height: 1.5rem; border-radius: 0.375rem; background: var(--c-bg); color: var(--c-strong); display: grid; place-items: center; }
    .hero-tldr-label { font-size: 0.74rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--fg-muted); }
    .hero-tldr-content { font-size: 0.85rem; color: var(--fg); line-height: 1.55; }
    .hero-tldr-content strong { color: var(--c-strong); }
    @media (max-width: 768px) { .hero-tldr { grid-template-columns: repeat(2, 1fr); } }

    /* ===== Entity card (data model — shadcn style) ===== */
    .entity-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; box-shadow: var(--shadow-xs); transition: all 0.18s; }
    .entity-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--c-border); }
    .entity-card-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
    .entity-name-block { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }
    .entity-name { font-size: 1rem; font-weight: 700; color: var(--fg); font-family: ui-monospace, monospace; }
    .entity-name-cn { font-size: 0.85rem; color: var(--fg-muted); }
    .entity-rel { display: flex; gap: 0.25rem; flex-wrap: wrap; }
    .entity-rel-tag { padding: 0.125rem 0.5rem; background: var(--c-bg); color: var(--c-strong); border: 1px solid var(--c-border); border-radius: 0.375rem; font-size: 0.7rem; font-weight: 500; }
    .entity-card-meta { font-size: 0.78rem; color: var(--fg-muted); margin-bottom: 0.75rem; padding-bottom: 0.625rem; border-bottom: 1px dashed var(--border); }
    .entity-fields { width: 100%; border-collapse: collapse; font-size: 0.825rem; }
    .entity-fields td { padding: 0.3rem 0.625rem 0.3rem 0; vertical-align: top; border-bottom: none; }
    .entity-fields td:first-child { padding-left: 0; }
    .ef-name { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; color: var(--fg); font-weight: 500; white-space: nowrap; }
    .ef-type { font-family: ui-monospace, monospace; color: #1d4ed8; white-space: nowrap; }
    .ef-desc { color: var(--fg-muted); width: 100%; }

    /* ===== Collapsible BR list ===== */
    .br-list-wrap .hidden { display: none !important; }
    .br-expand-btn { display: inline-flex; align-items: center; gap: 0.375rem; margin-top: 0.5rem; padding: 0.375rem 0.75rem; background: var(--bg-muted); border: 1px solid var(--border); color: var(--fg-muted); border-radius: var(--radius); font-size: 0.78rem; font-weight: 500; cursor: pointer; transition: all 0.12s; }
    .br-expand-btn:hover { background: var(--c-bg, var(--primary-soft)); color: var(--c-strong, var(--primary)); border-color: var(--c-border, var(--primary-soft)); }

    /* ===== AC list ===== */
    .ac-list { list-style: none; padding: 0; margin: 0; }
    .ac-list li { display: flex; gap: 0.625rem; align-items: flex-start; padding: 0.5rem 0; border-bottom: 1px dashed var(--border-soft); }
    .ac-list li:last-child { border-bottom: none; }
    .ac-list li::before { display: none; }
    .ac-code { background: #d1fae5; color: #047857; padding: 0.0625rem 0.4rem; border-radius: 0.25rem; font-family: ui-monospace, monospace; font-size: 0.75rem; font-weight: 600; flex-shrink: 0; margin-top: 0.0625rem; }
    .ac-list strong { color: #047857; font-weight: 600; }

    /* ===== Decision timetable ===== */
    .timetable { margin-top: 1.25rem; }
    .timetable-row { display: grid; grid-template-columns: 7rem 1fr 8rem 6rem; gap: 1rem; align-items: center; padding: 0.75rem 1rem; background: white; border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 0.5rem; }
    .timetable-date { font-family: ui-monospace, monospace; font-size: 0.8rem; font-weight: 600; color: #b45309; }
    .timetable-task { font-size: 0.875rem; color: var(--fg); }
    .timetable-owner { font-size: 0.825rem; color: var(--fg-muted); }
    @media (max-width: 768px) { .timetable-row { grid-template-columns: 1fr; gap: 0.25rem; } }

    .skill-card { background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.125rem; transition: all 0.18s; }
    .skill-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--c-border, var(--border)); }
    .skill-card-head { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.5rem; }
    .skill-card-icon { width: 1.75rem; height: 1.75rem; border-radius: 0.375rem; background: var(--c-bg); color: var(--c-strong); display: grid; place-items: center; flex-shrink: 0; font-size: 0.85rem; }
    .skill-card-name { font-family: ui-monospace, monospace; font-size: 0.875rem; font-weight: 600; }
    .skill-card-desc { font-size: 0.825rem; color: var(--fg-muted); margin-bottom: 0.625rem; line-height: 1.5; }
    .skill-card-trigger { padding: 0.375rem 0.625rem; background: var(--bg-muted); border-radius: 0.375rem; font-family: ui-monospace, monospace; font-size: 0.75rem; color: var(--fg); }

    .step-card { display: flex; gap: 1rem; padding: 1rem 1.25rem; background: white; border: 1px solid var(--border); border-radius: var(--radius-lg); margin-bottom: 0.75rem; }
    .step-card-num { width: 2rem; height: 2rem; border-radius: 9999px; background: var(--c-bg); color: var(--c-strong); display: grid; place-items: center; font-weight: 700; flex-shrink: 0; }
    .step-card-content { flex: 1; }
    .step-card-title { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.25rem; }
    .step-card-desc { font-size: 0.85rem; color: var(--fg-muted); line-height: 1.55; }

    footer { margin-top: 5rem; padding: 3rem 0; background: white; border-top: 1px solid var(--border); text-align: center; }
    footer .footer-brand { font-weight: 600; color: var(--fg); margin-bottom: 0.5rem; }
    footer .footer-meta { color: var(--fg-soft); font-size: 0.825rem; }
    footer .footer-meta a { color: var(--fg-muted); }

    /* Section accent colors */
    #overview     .section-eyebrow { color: #1d4ed8; } #overview     .section-eyebrow-dot { background: #1d4ed8; }
    #flows        .section-eyebrow { color: #0891b2; } #flows        .section-eyebrow-dot { background: #0891b2; }
    #architecture .section-eyebrow { color: #7e22ce; } #architecture .section-eyebrow-dot { background: #7e22ce; }
    #modules      .section-eyebrow { color: #ea580c; } #modules      .section-eyebrow-dot { background: #ea580c; }
    #prototypes   .section-eyebrow { color: #d97706; } #prototypes   .section-eyebrow-dot { background: #d97706; }
    #roles        .section-eyebrow { color: #4f46e5; } #roles        .section-eyebrow-dot { background: #4f46e5; }
    #rules        .section-eyebrow { color: #db2777; } #rules        .section-eyebrow-dot { background: #db2777; }
    #design       .section-eyebrow { color: #0d9488; } #design       .section-eyebrow-dot { background: #0d9488; }
    #ai-guide     .section-eyebrow { color: #4338ca; } #ai-guide     .section-eyebrow-dot { background: #4338ca; }
    #aisummary    .section-eyebrow { color: #16a34a; } #aisummary    .section-eyebrow-dot { background: #16a34a; }
    #oq           .section-eyebrow { color: #f59e0b; } #oq           .section-eyebrow-dot { background: #f59e0b; }

    svg { display: inline-block; vertical-align: middle; }
  </style>
</head>
<body>

<nav class="nav">
  <div class="nav-inner">
    <span class="nav-brand">
      <span class="nav-brand-icon">NPS</span>
      <span>NPS 问卷投放 · 评审</span>
    </span>
