<!-- ============================================================ -->
<!-- §9 AI GUIDE — AI 开发指南                                       -->
<!-- ============================================================ -->
<section id="ai-guide">
  <div class="section-header">
    <div>
      <div class="section-eyebrow"><span class="section-eyebrow-dot"></span> §9 AI Coding Guide</div>
      <h2 class="section-title">AI 开发指南</h2>
      <p class="section-subtitle">基于 Skill 的 Spec Coding 开发流程（Kiro Skills + Claude Code Skills）</p>
    </div>
  </div>

  <!-- Spec Coding 简介 -->
  <div class="grid grid-2" style="margin-bottom:1.5rem;">
    <div class="card clr-indigo">
      <div class="card-header">
        <div class="card-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
        <h3 class="card-title">什么是 Spec Coding</h3>
      </div>
      <div class="card-desc">
        <strong>以 Spec 文档为单一真相源（SSOT）的 AI 辅助开发模式</strong>。BR/EX/AC 编号体系形成"需求 → 测试 → 任务 → API"全链路追溯，AI 严格按文档生成代码并强制输出自检清单，确保实现可验证、可追溯。
      </div>
    </div>
    <div class="card clr-purple">
      <div class="card-header">
        <div class="card-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"/></svg></div>
        <h3 class="card-title">人在回路（Human-in-the-Loop）</h3>
      </div>
      <div class="card-desc">
        每个 Skill 遵循"先确认方案，再生成代码"原则。AI 输出实施方案表格供开发者确认，避免方向错误导致 Token 浪费与返工。
      </div>
    </div>
  </div>

  <!-- Skill 列表 -->
  <h3 style="font-size:1.05rem;font-weight:600;margin:1.5rem 0 1rem;">📚 角色 Skill</h3>
  <div class="grid grid-3">
    <!-- REPEAT:skill -->
    <div class="skill-card clr-{{SK_COLOR}}">
      <div class="skill-card-head">
        <div class="skill-card-icon">{{SK_ICON}}</div>
        <div class="skill-card-name">{{SK_NAME}}</div>
      </div>
      <div class="skill-card-desc">{{SK_DESC}}</div>
      <div class="skill-card-trigger">{{SK_TRIGGER}}</div>
    </div>
    <!-- /REPEAT -->
  </div>

  <!-- 工作流 -->
  <h3 style="font-size:1.05rem;font-weight:600;margin:1.75rem 0 1rem;">🔄 人在回路工作流（5 步）</h3>
  <div>
    <!-- REPEAT:ai_step -->
    <div class="step-card clr-{{AIS_COLOR}}">
      <div class="step-card-num">{{AIS_NUM}}</div>
      <div class="step-card-content">
        <div class="step-card-title">{{AIS_TITLE}}</div>
        <div class="step-card-desc">{{AIS_DESC}}</div>
      </div>
    </div>
    <!-- /REPEAT -->
  </div>

  <!-- 触发方式 -->
  <h3 style="font-size:1.05rem;font-weight:600;margin:1.75rem 0 1rem;">🎯 触发方式</h3>
  <div class="grid grid-3">
    <div class="card clr-blue">
      <div class="card-header">
        <div class="card-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M9 11H7v6h2zm5 0h-2v6h2zm5 0h-2v6h2zM3 7h18v12H3z"/></svg></div>
        <h3 class="card-title">方式 1 · 按任务编号（推荐）</h3>
      </div>
      <div class="skill-card-trigger" style="margin:0.75rem 0;">#flutter-dev 完成任务 QLIST-04</div>
      <p style="font-size:0.825rem;color:var(--fg-muted);">最完整：自动反查模块、依赖、验收标准</p>
    </div>
    <div class="card clr-green">
      <div class="card-header">
        <div class="card-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg></div>
        <h3 class="card-title">方式 2 · 按模块 ID</h3>
      </div>
      <div class="skill-card-trigger" style="margin:0.75rem 0;">#flutter-dev 为模块 5.2 生成首页</div>
      <p style="font-size:0.825rem;color:var(--fg-muted);">需手动指定模块编号，加载对应 PRD</p>
    </div>
    <div class="card clr-orange">
      <div class="card-header">
        <div class="card-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
        <h3 class="card-title">方式 3 · 自由描述</h3>
      </div>
      <div class="skill-card-trigger" style="margin:0.75rem 0;">#backend-dev 实现敏感词校验 Service</div>
      <p style="font-size:0.825rem;color:var(--fg-muted);">最灵活，AI 智能识别意图</p>
    </div>
  </div>
</section>

<!-- ============================================================ -->
<!-- §10 AI SUMMARY — AI 评审摘要                                    -->
<!-- ============================================================ -->
<section id="aisummary" class="section-alt">
  <div class="section-header">
    <div>
      <div class="section-eyebrow"><span class="section-eyebrow-dot"></span> §10 Review Decision Panel</div>
      <h2 class="section-title">评审决策面板</h2>
      <p class="section-subtitle">基于 spec 文档的评审决策面板：已对齐项 / 待澄清风险 / 开放问题 / 决策时间表</p>
    </div>
  </div>
  <div class="grid grid-2">
    <div class="card">
      <div class="card-header">
        <div class="card-icon" style="background:#d1fae5;color:#047857;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5L20 7"/></svg></div>
        <h3 class="card-title">已对齐项</h3>
      </div>
      <ul class="checklist">
        <!-- REPEAT:passed_item -->
        <li><span class="check-icon success">✓</span><span>{{PI_TEXT}}</span></li>
        <!-- /REPEAT -->
      </ul>
    </div>
    <div class="card">
      <div class="card-header">
        <div class="card-icon" style="background:#fef3c7;color:#b45309;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg></div>
        <h3 class="card-title">待澄清风险</h3>
      </div>
      <ul class="checklist">
        <!-- REPEAT:risk_item -->
        <li><span class="check-icon warning">!</span><span>{{RI_TEXT}}</span></li>
        <!-- /REPEAT -->
      </ul>
    </div>
  </div>

  <h3 style="font-size:1.05rem;font-weight:600;margin:2rem 0 1rem;">❓ 开放问题（OQ）</h3>
  <!-- REPEAT:oq -->
  <div class="oq-card">
    <span class="oq-id">{{OQ_ID}}</span>
    <div class="oq-q">{{OQ_QUESTION}}</div>
    <div class="oq-default"><strong>临时默认策略：</strong>{{OQ_DEFAULT}}</div>
  </div>
  <!-- /REPEAT -->

  <h3 style="font-size:1.05rem;font-weight:600;margin:2rem 0 1rem;">📅 决策时间表</h3>
  <div class="timetable">
    <div class="timetable-row" style="background:var(--bg-soft);font-weight:600;font-size:0.78rem;color:var(--fg-muted);text-transform:uppercase;letter-spacing:0.05em;">
      <div>截止日期</div>
      <div>决策项</div>
      <div>负责人</div>
      <div>状态</div>
    </div>
    <!-- REPEAT:decision_row -->
    <div class="timetable-row">
      <div class="timetable-date">{{DR_DATE}}</div>
      <div class="timetable-task">{{DR_TASK}}</div>
      <div class="timetable-owner">{{DR_OWNER}}</div>
      <div><span class="badge badge-{{DR_STATUS_BADGE}}">{{DR_STATUS}}</span></div>
    </div>
    <!-- /REPEAT -->
  </div>
</section>

</div>

<footer>
  <div class="container">
    <div class="footer-brand">NPS 问卷投放</div>
    <div class="footer-meta">
      文档版本 1.0.0 · 生成于 2026-07-09<br/><br/>
      <a href="#" target="_blank" rel="noopener">#</a>
    </div>
  </div>
</footer>

<div class="lightbox" id="lightbox">
  <button class="lightbox-close" aria-label="关闭">×</button>
  <img id="lightbox-img" src="" alt="" />
  <div class="lightbox-cap" id="lightbox-cap"></div>
</div>

<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
  mermaid.initialize({
    startOnLoad: false, theme: 'base',
    themeVariables: {
      primaryColor: '#eff6ff', primaryTextColor: '#1e3a8a', primaryBorderColor: '#bfdbfe',
      lineColor: '#94a3b8', secondaryColor: '#faf5ff', tertiaryColor: '#f8fafc',
      fontFamily: 'ui-sans-serif, system-ui, sans-serif', fontSize: '14px'
    }
  });
  // Render mermaid even inside hidden panes (sv-pane / tab-pane / arch-pane).
  // Mermaid 10 skips elements with zero layout, so temporarily reveal them.
  (async () => {
    const hiddenPanes = document.querySelectorAll('.sv-pane, .tab-pane, .arch-pane');
    const prev = [];
    hiddenPanes.forEach(p => { prev.push(p.style.display); p.style.display = 'block'; });
    try {
      await mermaid.run({ querySelector: '.mermaid' });
    } catch (e) { console.warn('mermaid render error', e); }
    hiddenPanes.forEach((p, i) => { p.style.display = prev[i] || ''; });
  })();
</script>
<script>
  // Active nav highlight
  const sections = document.querySelectorAll('section[id]');
  const links = document.querySelectorAll('.nav-links a');
  const navObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const id = e.target.id;
        links.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + id));
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });
  sections.forEach(s => navObs.observe(s));

  // Top tabs (only used in §2 flows)
  document.querySelectorAll('[data-tabs]').forEach(group => {
    const buttons = group.querySelectorAll('.tab-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        const parent = group.closest('section');
        parent.querySelectorAll('.tab-btn').forEach(b => {
          if (b.parentElement === group) b.classList.toggle('active', b === btn);
        });
        parent.querySelectorAll(':scope > .tab-pane').forEach(p => p.classList.toggle('active', p.id === target));
      });
    });
  });

  // Side-tabs (splitview)
  document.querySelectorAll('[data-sv]').forEach(list => {
    const section = list.closest('section');
    list.querySelectorAll('.splitview-item').forEach(item => {
      item.addEventListener('click', () => {
        const target = item.dataset.svtarget;
        list.querySelectorAll('.splitview-item').forEach(i => i.classList.toggle('active', i === item));
        section.querySelectorAll('.sv-pane').forEach(p => p.classList.toggle('active', p.id === target));
      });
    });
  });

  // Architecture sub-switch
  document.querySelectorAll('[data-archsub]').forEach(group => {
    const buttons = group.querySelectorAll('.arch-sub-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.archtab;
        group.parentElement.querySelectorAll('.arch-sub-btn').forEach(b => {
          if (b.parentElement === group) b.classList.toggle('active', b === btn);
        });
        group.parentElement.querySelectorAll('.arch-pane').forEach(p => p.classList.toggle('active', p.id === target));
      });
    });
  });

  // Prototype filter
  const protoGrid = document.querySelector('[data-protogrid]');
  const protoFilter = document.querySelector('[data-protofilter]');
  if (protoFilter && protoGrid) {
    protoFilter.querySelectorAll('.proto-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        protoFilter.querySelectorAll('.proto-filter-btn').forEach(b => b.classList.toggle('active', b === btn));
        const cat = btn.dataset.filter;
        protoGrid.querySelectorAll('.proto-card').forEach(card => {
          card.style.display = (cat === 'all' || card.dataset.cat === cat) ? '' : 'none';
        });
      });
    });
  }

  // BR list collapse/expand
  document.querySelectorAll('[data-expand-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const list = btn.previousElementSibling;
      if (!list || !list.classList.contains('br-list-wrap')) return;
      const expanded = btn.dataset.expanded === 'true';
      const items = list.querySelectorAll('li');
      const initialHidden = parseInt(btn.dataset.hiddenCount || '0');
      if (!expanded) {
        items.forEach((li, idx) => { if (idx >= 5) li.classList.remove('hidden'); });
        btn.dataset.expanded = 'true';
        btn.textContent = '收起 ↑';
      } else {
        items.forEach((li, idx) => { if (idx >= 5) li.classList.add('hidden'); });
        btn.dataset.expanded = 'false';
        btn.textContent = `展开剩余 ${initialHidden} 条 ↓`;
      }
    });
    const list = btn.previousElementSibling;
    if (list && list.classList.contains('br-list-wrap')) {
      const hiddenCount = list.querySelectorAll('li.hidden').length;
      btn.dataset.hiddenCount = String(hiddenCount);
    }
  });

  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxCap = document.getElementById('lightbox-cap');
  document.addEventListener('click', e => {
    const img = e.target.closest('[data-zoomable]');
    if (img) {
      lightboxImg.src = img.src;
      lightboxCap.textContent = img.dataset.cap || img.alt || '';
      lightbox.classList.add('active');
      return;
    }
    const btn = e.target.closest('[data-protoview]');
    if (btn) {
      lightboxImg.src = btn.dataset.protoview;
      lightboxCap.textContent = btn.dataset.protoname || '';
      lightbox.classList.add('active');
      return;
    }
  });
  function closeLightbox() { lightbox.classList.remove('active'); }
  lightbox.addEventListener('click', e => { if (e.target === lightbox || e.target === lightboxImg) closeLightbox(); });
  document.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>

</body>
</html>
