        <div class="modhead">
          <div class="modhead-meta">
            <span class="badge clr-{{MP_COLOR}}" style="background:var(--c-bg);color:var(--c-strong);border-color:var(--c-border);">模块 {{MP_ID}}</span>
            <span class="badge badge-{{MP_PRIORITY_BADGE}}">{{MP_PRIORITY}}</span>
