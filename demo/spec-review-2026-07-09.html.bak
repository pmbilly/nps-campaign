          <p class="modhead-desc">{{MP_DESC}}</p>
        </div>
        <div class="modgrid cols-2">
          <div class="modblock">
            <h4>📋 核心功能</h4>
            <ul>
              <!-- REPEAT:mp_feature --><li>{{MPF_TEXT}}</li><!-- /REPEAT -->
            </ul>
          </div>
          <div class="modblock">
            <h4>🔗 关联实体 / API</h4>
            <ul>
              <!-- REPEAT:mp_entity --><li><code>{{MPE_TEXT}}</code></li><!-- /REPEAT -->
            </ul>
            <h4 style="margin-top:1rem;">🔐 Permission Code</h4>
            <ul>
              <!-- REPEAT:mp_perm --><li><code>{{MPP_TEXT}}</code></li><!-- /REPEAT -->
            </ul>
          </div>
        </div>
        <div class="modblock" style="margin-top:1rem;">
          <h4>📐 关键业务规则</h4>
          <ul class="br-list br-list-wrap" data-collapse>
            <!-- REPEAT:mp_br -->
            <li class="{{MPB_HIDDEN}}">
              <span class="br-code">{{MPB_CODE}}</span>
              <span style="flex:1;">{{MPB_TEXT}}</span>
            </li>
            <!-- /REPEAT -->
          </ul>
          <!-- OPTIONAL:mp_br_expand -->
          <button class="br-expand-btn" data-expand-btn>展开剩余 {{MP_BR_HIDDEN_COUNT}} 条 ↓</button>
          <!-- /OPTIONAL -->
        </div>

        <!-- OPTIONAL:mp_ac -->
        <div class="modblock" style="margin-top:1rem;">
          <h4>✅ 验收标准（AC）</h4>
          <ul class="ac-list">
            <!-- REPEAT:mp_ac -->
            <li>
              <span class="ac-code">{{MPA_CODE}}</span>
              <span style="flex:1;">{{MPA_TEXT}}</span>
            </li>
            <!-- /REPEAT -->
          </ul>
        </div>
        <!-- /OPTIONAL -->
        <!-- OPTIONAL:mp_prototype -->
        <div style="margin-top:1rem;">
          <button class="modlink clr-{{MP_COLOR}}" data-protoview="{{MP_PROTO_SRC}}" data-protoname="{{MP_NAME}}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            查看原型
          </button>
        </div>
        <!-- /OPTIONAL -->
      </div>
      <!-- /REPEAT -->
    </div>
  </div>
</section>

